# URL do Web App publicado pelo Google Apps Script
# Obtenha essa URL ao publicar o Apps Script (passo 4 do README)
APPS_SCRIPT_WEBHOOK_URL="https://script.google.com/macros/s/COLE_SEU_ID_AQUI/exec"

# Token compartilhado entre Vercel e Apps Script (proteção contra spam)
# Use uma string longa e aleatória — o MESMO valor que está em TOKEN_SEGURANCA
# dentro do arquivo apps-script/Code.gs
# Gere uma com: openssl rand -hex 32
APPS_SCRIPT_SHARED_TOKEN="cole_aqui_o_mesmo_token_do_apps_script"
